# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=neo4j

# Supabase pgvector
PGVECTOR_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres
PGVECTOR_URL_SYNC=postgresql://postgres:postgres@localhost:5432/postgres
PGVECTOR_TABLE=document_chunks
EMBEDDING_DIMENSIONS=384

# Groq LLM
GROQ_API_KEY=gsk_your_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0

# Embeddings (uses sentence-transformers locally — no API key needed)
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Retrieval
TOP_K_CHUNKS=5
TOP_K_ENTITIES=10
MAX_HOPS=2

# Ingestion
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
